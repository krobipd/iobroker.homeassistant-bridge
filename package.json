{
  "name": "iobroker.homeassistant-bridge",
  "version": "0.8.10",
  "description": "Emulates a minimal Home Assistant server so devices expecting a Home Assistant dashboard can display any custom web URL.",
  "author": {
    "name": "krobi",
    "email": "krobi@power-dreams.com"
  },
  "homepage": "https://github.com/krobipd/ioBroker.homeassistant-bridge",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "homeassistant",
    "home-assistant",
    "shelly",
    "wall display",
    "vis",
    "bridge",
    "emulation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/krobipd/ioBroker.homeassistant-bridge"
  },
  "bugs": {
    "url": "https://github.com/krobipd/ioBroker.homeassistant-bridge/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "express": "^5.0.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@iobroker/types": "^7.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^25.0.0",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "main": "build/main.js",
  "files": [
    "admin/",
    "build/",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "rm -rf ./build",
    "build:ts": "tsc -p tsconfig.build.json",
    "build": "npm run build:ts",
    "watch": "tsc -w",
    "check": "tsc --noEmit",
    "test": "npm run build:test && mocha --exit \"build/test/**/*.js\"",
    "test:ci": "npm run build:test && mocha --exit --reporter spec \"build/test/**/*.js\"",
    "test:package": "npm run build:test && mocha --exit \"build/test/testPackageFiles.js\"",
    "test:integration": "npm run build:test && mocha --exit \"build/test/**/*.js\"",
    "build:test": "rm -rf ./build && tsc -p tsconfig.test.json",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "npm run build",
    "translate": "translate-adapter",
    "release": "release-script"
  }
}
